
import java.util.Scanner;

public class Main {
    static Scanner scan = new Scanner(System.in);
    static int score = 0;

    public static void main(String[] args) {

        System.out.println("WELCOME TO THE QUIZ MASTER 100");
        System.out.println();

        int a = 0;

        while (a != 5) {
            System.out.println("Please choose a subject:");
            System.out.println();
            System.out.println("1: MATH");
            System.out.println("2: PROGRAMMING");
            System.out.println("3: SPORTS");
            System.out.println("4: SURPRISE");
            System.out.println("5: QUIT");

            a = scan.nextInt();

            while (a < 1 || a > 5) {
                System.out.println("Please choose only between 1 and 5:");
                a = scan.nextInt();
            }
            scan.nextLine();

            if (a == 1) {
                playMath();
            } else if (a == 2) {
                playProgramming();
            } else if (a == 3) {
                playSports();
            } else if (a == 4) {
                playSurprise();
            } else if (a == 5) {
                System.out.println("Thanks for playing QUIZ MASTER 100!");
            }
        }

        System.out.println("Your score is: " + score);
    }

    static void playMath() {
        System.out.println("Your subject will be the fascinating world of MATH");
        System.out.println();
        System.out.println("Please answer the following question:");
        System.out.println();
        Question q = new Question("Which of the following numbers is odd?", "2, 3, 6, 8", "3");
        if (q.ask(scan)) {
            score++;
        }
    }

    static void playProgramming() {
        System.out.println("Your subject will be the never ending void of zeros and ones; PROGRAMMING");
        System.out.println();
        System.out.println("Please answer the following question:");
        System.out.println();
        Question q = new Question("Which of the following datatypes is non-primitive?", "int, byte, String, short", "String");
        if (q.ask(scan)) {
            score++;
        }
    }

    static void playSports() {
        System.out.println("Your subject will be the heroic universe of SPORTS");
        System.out.println();
        System.out.println("Please answer the following question:");
        System.out.println();
        Question q = new Question("Which of the following athletes is still active?", "Dirk Nowitzki, Mike Tyson, Cristiano Ronaldo, Marco Streller", "Cristiano Ronaldo");
        if (q.ask(scan)) {
            score++;
        }
    }

    static void playSurprise() {
        System.out.println("Your subject will be a SURPRISE");
        System.out.println();
        System.out.println("Please answer the following question:");
        System.out.println();
        Question q = new Question("Which of the following presidents was not shot?", "Donald Trump, John F. Kennedy, Abraham Lincoln, Barack Obama", "Barack Obama");
        if (q.ask(scan)) {
            score++;
        }
    }
}
